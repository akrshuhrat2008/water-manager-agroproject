# Конфигурация приложения Agro Water
# Скопируйте этот файл в .env и заполните значения

# === База данных ===
# URL подключения к базе данных (по умолчанию SQLite)
DATABASE_URL=sqlite:///./agro_water.db

# Для PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/agro_water

# === Погодные сервисы ===
# Open-Meteo API (бесплатно, не требует ключа)
# Используется по умолчанию для получения прогноза погоды
USE_MOCK_WEATHER=false

# OpenWeatherMap API (опционально, для backup)
# Получить ключ: https://openweathermap.org/api
OPENWEATHER_API_KEY=

# === Метод расчета водопользования ===
# true = научный метод FAO-56 с эвапотранспирацией (ET₀)
# false = упрощенный метод на основе коэффициентов
USE_SCIENTIFIC_METHOD=true

# === Настройки приложения ===
# Режим отладки (true/false)
DEBUG=false

# Хост и порт для запуска
HOST=0.0.0.0
PORT=8000

# === Безопасность ===
# Секретный ключ для JWT токенов (генерируйте случайный)
# Генерация: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here

# CORS Origins (разрешенные домены для API)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# === Логирование ===
# Уровень логирования (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# === Кеширование погоды ===
# Время жизни кеша погоды в часах
WEATHER_CACHE_HOURS=6

# === Дополнительные настройки ===
# Язык по умолчанию
DEFAULT_LANGUAGE=ru

# Часовой пояс
TIMEZONE=Asia/Dushanbe
